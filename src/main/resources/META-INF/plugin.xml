<idea-plugin>
    <id>com.github.ttereshchenko.eml-helper</id>
    <name>EML Helper</name>
    <vendor email="" url="https://github.com/ttereshchenko/eml-helper">ttereshchenko</vendor>
    <description><![CDATA[
        <p>Syntax highlighting, code folding, and editor support for EML (Email Message / RFC 822) files.</p>
        <ul>
          <li>Syntax highlighting for headers, MIME boundaries, and body content</li>
          <li>MIME part code folding — collapse and expand nested message parts</li>
          <li>Per-header color customization via the color scheme editor</li>
          <li>Name-only highlighting mode (highlight header name, not value)</li>
          <li>Global highlighting toggle under Settings → Editor → EML</li>
          <li>Add custom headers to the highlight list</li>
        </ul>
    ]]></description>
    <idea-version since-build="243"/>
    <extensions defaultExtensionNs="com.intellij">
        <fileType name="EML"
                  language="EML"
                  implementationClass="com.github.ttereshchenko.emlhelper.EmlFileType"
                  fieldName="INSTANCE"
                  extensions="eml"/>

        <lang.parserDefinition
                language="EML"
                implementationClass="com.github.ttereshchenko.emlhelper.lexer.EmlParserDefinition"/>

        <lang.syntaxHighlighterFactory
                language="EML"
                implementationClass="com.github.ttereshchenko.emlhelper.highlighting.EmlSyntaxHighlighterFactory"/>

        <lang.foldingBuilder
                language="EML"
                implementationClass="com.github.ttereshchenko.emlhelper.folding.EmlFoldingBuilder"/>

        <applicationService serviceImplementation="com.github.ttereshchenko.emlhelper.settings.EmlHeaderSettings"/>

        <annotator language="EML" implementationClass="com.github.ttereshchenko.emlhelper.highlighting.EmlHeaderAnnotator"/>

        <applicationConfigurable parentId="editor" id="eml.settings"
                displayName="EML" instance="com.github.ttereshchenko.emlhelper.settings.EmlHeaderSettingsConfigurable"/>

        <colorSettingsPage implementation="com.github.ttereshchenko.emlhelper.highlighting.EmlColorSettingsPage"/>
    </extensions>
</idea-plugin>
