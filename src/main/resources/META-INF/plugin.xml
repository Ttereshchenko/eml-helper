<idea-plugin>
    <id>org.example.eml-helper</id>
    <name>EML Helper</name>
    <vendor>org.example</vendor>
    <description>Helper for working with EML (Email Message format) files.</description>
    <idea-version since-build="243"/>
    <extensions defaultExtensionNs="com.intellij">
        <fileType name="EML"
                  language="EML"
                  implementationClass="org.example.EmlFileType"
                  fieldName="INSTANCE"
                  extensions="eml"/>

        <lang.parserDefinition
                language="EML"
                implementationClass="org.example.lexer.EmlParserDefinition"/>

        <lang.syntaxHighlighterFactory
                language="EML"
                implementationClass="org.example.highlighting.EmlSyntaxHighlighterFactory"/>

        <lang.foldingBuilder
                language="EML"
                implementationClass="org.example.folding.EmlFoldingBuilder"/>

        <applicationService serviceImplementation="org.example.settings.EmlHeaderSettings"/>

        <annotator language="EML" implementationClass="org.example.highlighting.EmlHeaderAnnotator"/>

        <applicationConfigurable parentId="editor" id="eml.settings"
                displayName="EML" instance="org.example.settings.EmlHeaderSettingsConfigurable"/>

        <colorSettingsPage implementation="org.example.highlighting.EmlColorSettingsPage"/>
    </extensions>
</idea-plugin>
